  "compilation": {
    "policyTitle": "Procurement and Vendor Change Policy",
    "policySummary": "Proposed controls for human review covering approval thresholds, document chronology, amount and currency matching, delivery evidence, bank-change verification, and segregation of duties. These controls remain unapproved until reviewed by a human.",
    "controls": [
      {
        "id": "PVC-001",
        "title": "Two approvers above EUR 10,000",
        "description": "Require two distinct approvers when the transaction amount exceeds EUR 10,000.",
        "condition": "Transaction currency is EUR and transaction amount is greater than 10000.",
        "requiredEvidence": ["Transaction amount and currency", "Approval records", "Unique approver identities"],
        "severity": "HIGH",
        "controlType": "APPROVAL_THRESHOLD",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": 10000, "currency": "EUR", "requiredApprovers": 2 },
        "semanticReviewQuestion": null
      },
      {
        "id": "PVC-002",
        "title": "Purchase order predates invoice",
        "description": "Verify that the purchase order date is earlier than the invoice date.",
        "condition": "A purchase order and invoice are associated with the transaction.",
        "requiredEvidence": ["Purchase order showing issue date", "Invoice showing invoice date"],
        "severity": "HIGH",
        "controlType": "PO_BEFORE_INVOICE",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": null, "currency": null, "requiredApprovers": null },
        "semanticReviewQuestion": null
      },
      {
        "id": "PVC-003",
        "title": "Purchase order and invoice amount match",
        "description": "Verify that the purchase order amount equals the invoice amount.",
        "condition": "A purchase order and invoice are associated with the transaction.",
        "requiredEvidence": ["Purchase order amount", "Invoice amount"],
        "severity": "HIGH",
        "controlType": "AMOUNT_MATCH",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": null, "currency": null, "requiredApprovers": null },
        "semanticReviewQuestion": null
      },
      {
        "id": "PVC-004",
        "title": "Purchase order and invoice currency match",
        "description": "Verify that the purchase order currency equals the invoice currency.",
        "condition": "A purchase order and invoice are associated with the transaction.",
        "requiredEvidence": ["Purchase order currency", "Invoice currency"],
        "severity": "HIGH",
        "controlType": "CURRENCY_MATCH",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": null, "currency": null, "requiredApprovers": null },
        "semanticReviewQuestion": null
      },
      {
        "id": "PVC-005",
        "title": "Delivery evidence exists",
        "description": "Require delivery evidence for the transaction.",
        "condition": "The transaction involves delivery of goods or services.",
        "requiredEvidence": ["Delivery receipt, proof of service, goods receipt, or equivalent delivery record"],
        "severity": "HIGH",
        "controlType": "DELIVERY_EVIDENCE",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": null, "currency": null, "requiredApprovers": null },
        "semanticReviewQuestion": null
      },
      {
        "id": "PVC-006",
        "title": "Independent verification of bank-details changes",
        "description": "Require independent verification whenever vendor bank details are changed.",
        "condition": "Vendor bank details have changed.",
        "requiredEvidence": ["Bank-change request", "Independent verification record", "Identity of verifier", "Verification date and method"],
        "severity": "CRITICAL",
        "controlType": "BANK_CHANGE_VERIFICATION",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": null, "currency": null, "requiredApprovers": null },
        "semanticReviewQuestion": null
      },
      {
        "id": "PVC-007",
        "title": "Initiator and approver segregation",
        "description": "Verify that the transaction initiator and approver are different people.",
        "condition": "A transaction has been initiated and submitted for approval.",
        "requiredEvidence": ["Initiator identity", "Approver identity", "Approval audit trail"],
        "severity": "HIGH",
        "controlType": "SEGREGATION_OF_DUTIES",
        "enabled": false,
        "deterministicParameters": { "thresholdAmount": null, "currency": null, "requiredApprovers": null },
        "semanticReviewQuestion": null
      }
    ]
  },
